---
import SiteLayout from "../layouts/SiteLayout.astro";

const navLinks = [
  { href: "#services", label: "Services" },
  { href: "#why", label: "Why us" },
  { href: "#how", label: "How it works" },
  { href: "#contact", label: "Contact" },
];

const services = [
  {
    title: "Repairs",
    body:
      "Leaky faucets, sticking doors, drywall dings, running toilets, that thing that's been broken for months. We fix it properly.",
    icon: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
  },
  {
    title: "Maintenance",
    body:
      "Keep small issues from becoming big ones with regular tune-ups, caulking, gutter checks, and seasonal to-do lists — handled.",
    icon: `<path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16z"/><path d="M12 8v4l3 2"/>`,
  },
  {
    title: "Odd jobs &amp; to-dos",
    body:
      "That running list on the fridge — the little fixes and small projects that never quite get done. Hand it over and cross it off.",
    icon: `<path d="M11 6h9M11 12h9M11 18h9"/><path d="M4 6l1 1 2-2M4 12l1 1 2-2M4 18l1 1 2-2"/>`,
  },
  {
    title: "Installations",
    body:
      "Ceiling fans, light fixtures, shelving, TVs, faucets, hardware, that flat-pack furniture. Mounted level and secure.",
    icon: `<path d="M12 2v6m0 0l-3-3m3 3l3-3"/><rect x="4" y="8" width="16" height="12" rx="2"/><path d="M8 20v-4h8v4"/>`,
  },
  {
    title: "Seasonal &amp; outdoor",
    body:
      "Deck repairs, fence fixes, pressure washing, weatherproofing, and getting the yard and exterior ready for what's next.",
    icon: `<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>`,
  },
  {
    title: "Not sure? Just ask",
    body:
      "If it's on your house and it's bugging you, send us a message. If it's not something we do, we'll point you to someone great.",
    icon: `<path d="M12 2l2.4 7.4H22l-6 4.4 2.3 7.2L12 16.6 5.7 21l2.3-7.2-6-4.4h7.6z"/>`,
  },
];

const why = [
  {
    title: "Careful &amp; tidy",
    body:
      "We treat your home with respect and clean up when the job's done — you'd hardly know we were there.",
    icon: `<path d="M5 3v4M3 5h4M6 17v4M4 19h4"/><path d="M13 3l2.4 6.6L22 12l-6.6 2.4L13 21l-2.4-6.6L4 12l6.6-2.4z"/>`,
  },
  {
    title: "Reliable &amp; on time",
    body:
      "We show up when we say we will and keep you posted. Your time matters as much as ours.",
    icon: `<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>`,
  },
  {
    title: "Local &amp; familiar",
    body:
      "We live and work in the St. Louis area. Your neighbors are our customers, and word of mouth is everything to us.",
    icon: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>`,
  },
  {
    title: "Upfront pricing",
    body:
      "A clear written quote before we start. No mystery fees, no pressure — just an honest number.",
    icon: `<path d="M12 1v22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
  },
];

const steps = [
  {
    n: "1",
    title: "Send us a message",
    body:
      "Send us a few details and a photo of what's going on — that helps us understand the job right away.",
  },
  {
    n: "2",
    title: "Get a free quote",
    body:
      "We'll give you a clear, written price and a realistic timeline — no obligation to book.",
  },
  {
    n: "3",
    title: "Done right",
    body:
      "We do the work carefully, clean up, and make sure you're happy before we call it finished.",
  },
];

---

<SiteLayout>
  <a
    class="absolute left-[-999px] top-0 z-[300] rounded-br-lg bg-charcoal px-4 py-2.5 text-white focus:left-0"
    href="#main">Skip to content</a
  >

  <!-- HEADER / NAV -->
  <header
    class="sticky top-0 z-[100] border-b border-line bg-[rgba(251,250,247,0.92)] backdrop-blur-[8px] backdrop-saturate-[1.4]"
  >
    <div
      class="mx-auto flex max-w-[1180px] items-center justify-between gap-4 px-5 py-3"
    >
      <a
        class="flex items-center no-underline"
        href="#top"
        aria-label="Sphyros Home Services home"
      >
        <img
          class="h-[68px] w-auto flex-none"
          src="/brand-kit/logo.png"
          alt="Sphyros Home Services"
          width="720"
          height="472"
        />
      </a>

      <nav class="hidden items-center gap-7 min-[960px]:flex" aria-label="Primary">
        {
          navLinks.map((item) => (
            <a
              href={item.href}
              class="text-[15px] font-semibold text-charcoal-soft no-underline hover:text-amber-dark"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="hidden items-center gap-3 min-[960px]:flex">
        <a
          class="inline-flex items-center justify-center gap-[9px] rounded-xl bg-gradient-to-b from-amber to-amber-dark px-[22px] py-[13px] text-[16px] font-bold text-white no-underline shadow-[0_8px_20px_rgba(154,119,52,0.35)] transition-[transform,box-shadow] duration-150 hover:-translate-y-0.5 hover:shadow-[0_12px_26px_rgba(154,119,52,0.45)]"
          href="#contact">Get a free quote</a
        >
      </div>

      <button
        class="inline-flex items-center gap-2 rounded-[11px] border-[1.5px] border-sand-300 bg-cream px-3 py-[9px] text-[14px] font-bold text-charcoal min-[960px]:hidden"
        id="navToggle"
        aria-expanded="false"
        aria-controls="mobileMenu"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2.4"
          stroke-linecap="round"
          aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"></path></svg
        >
        Menu
      </button>
    </div>

    <div
      id="mobileMenu"
      class="hidden border-t border-line bg-sand-50 min-[960px]:!hidden"
      aria-label="Mobile"
    >
      <div class="flex flex-col gap-1.5 px-5 pb-5 pt-3.5">
        {
          navLinks.map((item) => (
            <a
              href={item.href}
              class="rounded-[10px] px-2.5 py-3 font-semibold text-charcoal no-underline hover:bg-sand-100"
            >
              {item.label}
            </a>
          ))
        }
        <a
          class="mt-2 inline-flex w-full items-center justify-center gap-[9px] rounded-xl bg-gradient-to-b from-amber to-amber-dark px-[22px] py-[13px] text-[16px] font-bold text-white no-underline shadow-[0_8px_20px_rgba(154,119,52,0.35)]"
          href="#contact">Get a free quote</a
        >
      </div>
    </div>
  </header>

  <main id="main">
    <a id="top"></a>

    <!-- HERO -->
    <section class="relative overflow-hidden py-11 pb-5 min-[960px]:py-16 min-[960px]:pb-10" aria-labelledby="hero-h">
      <div
        class="pointer-events-none absolute inset-0 z-0"
        style="background: radial-gradient(1100px 460px at 78% -8%, rgba(193,154,85,.20), transparent 60%), radial-gradient(760px 420px at 6% 108%, rgba(61,107,79,.12), transparent 60%);"
        aria-hidden="true"
      >
      </div>
      <div class="relative z-[1] mx-auto max-w-[1180px] px-5">
        <div
          class="grid grid-cols-1 gap-[30px] min-[960px]:grid-cols-[1.1fr_0.9fr] min-[960px]:items-center min-[960px]:gap-12"
        >
          <div>
            <h1
              class="text-charcoal"
              style="font-size:clamp(2.3rem,7vw,4rem);"
              id="hero-h"
            >
              Home repairs &amp; small projects, <em class="not-italic text-amber-dark"
                >done right</em
              >.
            </h1>
            <p
              class="mb-1.5 max-w-[34ch] text-charcoal-soft"
              style="font-size:clamp(1.05rem,2.4vw,1.28rem);"
            >
              From the small fixes you keep putting off to the odd jobs around the
              house — honest work, done on time and cleaned up after.
            </p>
            <div class="my-4 inline-flex items-center gap-2 text-[15px] font-semibold text-charcoal">
              <svg
                viewBox="0 0 24 24"
                class="h-[18px] w-[18px] text-amber-dark"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle
                  cx="12"
                  cy="10"
                  r="3"></circle></svg
              >
              Proudly serving St. Louis and the surrounding area
            </div>
            <div class="mb-3.5">
              <a
                class="inline-flex items-center justify-center gap-[9px] rounded-xl bg-gradient-to-b from-amber to-amber-dark px-[30px] py-4 text-[18px] font-bold text-white no-underline shadow-[0_8px_20px_rgba(154,119,52,0.35)] transition-[transform,box-shadow] duration-150 hover:-translate-y-0.5 hover:shadow-[0_12px_26px_rgba(154,119,52,0.45)]"
                href="#contact">Get a free quote</a
              >
            </div>
            <div class="mt-[22px] flex flex-wrap gap-x-[18px] gap-y-2">
              {
                ["Free quotes", "Upfront pricing", "Locally owned"].map(
                  (t) => (
                    <span class="flex items-center gap-[7px] text-[14px] font-semibold text-charcoal-soft">
                      <svg
                        viewBox="0 0 24 24"
                        class="h-[17px] w-[17px] text-green"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M20 6L9 17l-5-5" />
                      </svg>
                      <Fragment set:html={t} />
                    </span>
                  ),
                )
              }
            </div>
          </div>

          <aside
            class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-charcoal to-[#363b45] p-[26px] text-sand-100 shadow-[0_24px_60px_rgba(38,43,51,0.2)]"
            aria-label="What to expect"
          >
            <div
              class="pointer-events-none absolute -right-[60px] -top-[60px] h-[220px] w-[220px] rounded-full"
              style="background: radial-gradient(circle, rgba(193,154,85,.55), transparent 65%);"
              aria-hidden="true"
            >
            </div>
            <h3 class="relative text-[1.35rem] text-white">
              Straightforward from the first message
            </h3>
            <p class="relative mb-[18px] text-sand-200">
              No surprises, no pressure — just a clear plan and a fair price.
            </p>
            <ul class="relative m-0 grid list-none gap-3 p-0">
              {
                [
                  {
                    n: "1",
                    b: "Tell us what's going on",
                    s: "Send us a few details and a photo of the problem.",
                  },
                  {
                    n: "2",
                    b: "Get a free, written quote",
                    s: "Clear scope and price before we start.",
                  },
                  {
                    n: "3",
                    b: "We handle it, start to finish",
                    s: "On time, tidy, and built to last.",
                  },
                ].map((li) => (
                  <li class="flex items-start gap-3 rounded-xl border border-white/10 bg-white/[0.06] px-3.5 py-3">
                    <span class="grid h-[30px] w-[30px] flex-none place-items-center rounded-[9px] bg-amber font-display font-normal text-charcoal">
                      {li.n}
                    </span>
                    <span>
                      <b class="block text-[15px] text-white">{li.b}</b>
                      <span class="text-[13.5px] text-sand-200">{li.s}</span>
                    </span>
                  </li>
                ))
              }
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section
      class="border-y border-line bg-cream py-14"
      id="services"
      aria-labelledby="services-h"
    >
      <div class="mx-auto max-w-[1180px] px-5">
        <div class="mb-[34px] max-w-[640px]">
          <span
            class="mb-2.5 inline-block text-[12.5px] font-bold uppercase tracking-[0.12em] text-amber-dark"
            >What we do</span
          >
          <h2 class="text-charcoal" style="font-size:clamp(1.8rem,4.5vw,2.6rem);" id="services-h">
            One trusted name for the whole house
          </h2>
          <p class="m-0 text-[1.05rem] text-charcoal-soft">
            The everyday repairs, upkeep, and small projects that keep a home
            running. Here's what we take on most.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-4 min-[720px]:grid-cols-2 min-[960px]:grid-cols-3">
          {
            services.map((s) => (
              <article class="rounded-[18px] border border-line bg-sand-50 p-6 transition-[transform,box-shadow,border-color] duration-150 hover:-translate-y-1 hover:border-sand-300 hover:shadow-[var(--shadow)]">
                <div class="mb-4 grid h-[54px] w-[54px] place-items-center rounded-[14px] border border-line bg-gradient-to-br from-sand-200 to-sand-100 text-amber-deep">
                  <svg
                    viewBox="0 0 24 24"
                    class="h-7 w-7"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.9"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    set:html={s.icon}
                  />
                </div>
                <h3 class="mb-1.5 text-[1.25rem] text-charcoal" set:html={s.title} />
                <p class="m-0 text-[0.97rem] text-charcoal-soft" set:html={s.body} />
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- WHY -->
    <section class="py-14" id="why" aria-labelledby="why-h">
      <div class="mx-auto max-w-[1180px] px-5">
        <div class="mb-[34px] max-w-[640px]">
          <span
            class="mb-2.5 inline-block text-[12.5px] font-bold uppercase tracking-[0.12em] text-amber-dark"
            >Why homeowners choose us</span
          >
          <h2 class="text-charcoal" style="font-size:clamp(1.8rem,4.5vw,2.6rem);" id="why-h">
            Work you can trust, done right
          </h2>
          <p class="m-0 text-[1.05rem] text-charcoal-soft">
            Sphyros means "hammer" — hands-on, solid, built to last. That's the
            standard on every job, right down to the smallest fix.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-4 min-[720px]:grid-cols-2">
          {
            why.map((w) => (
              <div class="flex items-start gap-4 rounded-[18px] border border-line bg-cream p-[22px]">
                <span class="grid h-[52px] w-[52px] flex-none place-items-center rounded-[14px] bg-green text-white" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    class="h-[26px] w-[26px]"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={w.icon}
                  />
                </span>
                <div>
                  <h3 class="mb-1 text-[1.15rem] text-charcoal" set:html={w.title} />
                  <p class="m-0 text-[0.96rem] text-charcoal-soft" set:html={w.body} />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- HOW -->
    <section
      class="border-t border-line bg-gradient-to-b from-sand-100 to-sand-50 py-14"
      id="how"
      aria-labelledby="how-h"
    >
      <div class="mx-auto max-w-[1180px] px-5">
        <div class="mb-[34px] max-w-[640px]">
          <span
            class="mb-2.5 inline-block text-[12.5px] font-bold uppercase tracking-[0.12em] text-amber-dark"
            >How it works</span
          >
          <h2 class="text-charcoal" style="font-size:clamp(1.8rem,4.5vw,2.6rem);" id="how-h">
            Getting help is refreshingly simple
          </h2>
          <p class="m-0 text-[1.05rem] text-charcoal-soft">
            Three easy steps between "this is annoying" and "consider it handled."
          </p>
        </div>
        <div class="grid grid-cols-1 gap-[18px] min-[720px]:grid-cols-3">
          {
            steps.map((step) => (
              <div class="rounded-[18px] border border-line bg-cream px-6 py-[26px]">
                <div class="mb-3.5 grid h-12 w-12 place-items-center rounded-full bg-charcoal font-display text-[1.4rem] font-normal text-cream">
                  {step.n}
                </div>
                <h3 class="text-[1.25rem] text-charcoal">{step.title}</h3>
                <p class="m-0 text-charcoal-soft">{step.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="bg-charcoal py-14 text-sand-100" id="contact" aria-labelledby="contact-h">
      <div class="mx-auto max-w-[1180px] px-5">
        <div class="mb-[34px] max-w-[640px]">
          <span
            class="mb-2.5 inline-block text-[12.5px] font-bold uppercase tracking-[0.12em] text-sand-300"
            >Get started</span
          >
          <h2 class="text-white" style="font-size:clamp(1.8rem,4.5vw,2.6rem);" id="contact-h">
            Get your free quote
          </h2>
          <p class="m-0 text-[1.05rem] text-sand-200">
            Send a few details and we'll get back to you fast — usually the same
            day. The form below is the quickest way to reach us.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-7 min-[720px]:grid-cols-[1.2fr_0.9fr]">
          <div class="rounded-[22px] bg-cream p-[26px] text-ink shadow-[0_24px_60px_rgba(38,43,51,0.2)]">
            <form id="quoteForm" novalidate>
              <h3 class="text-[1.4rem] text-charcoal">Tell us about your project</h3>
              <div class="mb-[15px]">
                <label class="mb-1.5 block text-[14px] font-semibold text-charcoal" for="name"
                  >Your name</label
                >
                <input
                  class="w-full rounded-[11px] border-[1.5px] border-sand-300 bg-sand-50 px-3.5 py-[13px] text-[16px] text-ink focus:border-amber focus:bg-white"
                  id="name"
                  name="name"
                  type="text"
                  autocomplete="name"
                  required
                  placeholder="Jordan Smith"
                />
              </div>
              <div class="mb-[15px]">
                <label class="mb-1.5 block text-[14px] font-semibold text-charcoal" for="email"
                  >Email</label
                >
                <input
                  class="w-full rounded-[11px] border-[1.5px] border-sand-300 bg-sand-50 px-3.5 py-[13px] text-[16px] text-ink focus:border-amber focus:bg-white"
                  id="email"
                  name="email"
                  type="email"
                  autocomplete="email"
                  required
                  placeholder="Best email to reach you"
                />
              </div>
              <div class="mb-[15px]">
                <label class="mb-1.5 block text-[14px] font-semibold text-charcoal" for="details"
                  >What do you need done?</label
                >
                <textarea
                  class="min-h-[110px] w-full resize-y rounded-[11px] border-[1.5px] border-sand-300 bg-sand-50 px-3.5 py-[13px] text-[16px] text-ink focus:border-amber focus:bg-white"
                  id="details"
                  name="details"
                  required
                  placeholder="e.g. Two interior doors sticking, a leaky kitchen faucet, and a ceiling fan to install."
                ></textarea>
              </div>
              <p class="my-1 mb-4 text-[13px] text-charcoal-soft">
                By submitting, you agree to be contacted about your request. We
                never share your info.
              </p>
              <button
                class="inline-flex w-full items-center justify-center gap-[9px] rounded-xl bg-gradient-to-b from-amber to-amber-dark px-[30px] py-4 text-[18px] font-bold text-white shadow-[0_8px_20px_rgba(154,119,52,0.35)] transition-[transform,box-shadow] duration-150 hover:-translate-y-0.5 hover:shadow-[0_12px_26px_rgba(154,119,52,0.45)]"
                type="submit">Request my free quote</button
              >
            </form>
            <div class="hidden px-2.5 py-5 text-center" id="thanks" role="status" aria-live="polite">
              <div class="mx-auto mb-3.5 grid h-[70px] w-[70px] place-items-center rounded-full bg-green" aria-hidden="true">
                <svg
                  viewBox="0 0 24 24"
                  class="h-[38px] w-[38px] text-white"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg
                >
              </div>
              <h3 class="text-charcoal">Thanks — we've got it!</h3>
              <p class="m-0 text-charcoal-soft">
                We'll reach out shortly to talk through your project.
              </p>
            </div>
          </div>

          <aside class="flex flex-col gap-4">
            <div class="rounded-[18px] border border-white/[0.14] bg-white/[0.06] p-6">
              <small
                class="mb-1.5 block text-[12px] font-semibold uppercase tracking-[0.1em] text-sand-300"
                >Fast response</small
              >
              <p class="mb-3.5 mt-0 font-display text-[1.5rem] font-normal leading-tight text-white">
                We reply to every request quickly — usually the same day.
              </p>
              <div class="flex items-center gap-3 text-[15px] text-sand-200">
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5 flex-none text-amber"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"
                  ></path></svg
                >
                Available Mon–Sat
              </div>
              <div class="mt-3 flex items-center gap-3 text-[15px] text-sand-200">
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5 flex-none text-amber"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                  ></path><circle cx="12" cy="10" r="3"></circle></svg
                >
                Proudly serving St. Louis and the surrounding area
              </div>
            </div>
            <div class="rounded-[18px] border border-white/[0.14] bg-white/[0.06] p-6">
              <small
                class="mb-1.5 block text-[12px] font-semibold uppercase tracking-[0.1em] text-sand-300"
                >What happens next</small
              >
