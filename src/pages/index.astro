  <script is:inline>
    (function () {
      // Mobile nav toggle
      var toggle = document.getElementById("navToggle");
      var menu = document.getElementById("mobileMenu");
      if (toggle && menu) {
        toggle.addEventListener("click", function () {
          var open = menu.classList.toggle("hidden") === false;
          toggle.setAttribute("aria-expanded", open ? "true" : "false");
        });
        menu.querySelectorAll("a").forEach(function (a) {
          a.addEventListener("click", function () {
            menu.classList.add("hidden");
            toggle.setAttribute("aria-expanded", "false");
          });
        });
      }
      // Quote form -> FormSubmit (AJAX) -> thank-you state
      var form = document.getElementById("quoteForm");
      var thanks = document.getElementById("thanks");
      if (form && thanks) {
        var ENDPOINT = "https://formsubmit.co/ajax/info@sphyroshome.com";
        var submitBtn = form.querySelector('button[type="submit"]');
        var errorEl = null;
        form.addEventListener("submit", function (e) {
          e.preventDefault();
          if (!form.checkValidity()) {
            form.reportValidity();
            return;
          }
          // Clear any previous inline error
          if (errorEl) {
            errorEl.parentNode.removeChild(errorEl);
            errorEl = null;
          }
          var originalLabel = submitBtn ? submitBtn.innerHTML : "";
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = "Sending…";
          }
          var payload = {};
          new FormData(form).forEach(function (value, key) {
            payload[key] = value;
          });
          payload._subject = "New quote request — Sphyros Home Services";
          payload._template = "table";
          payload._captcha = "false";
          payload._autoresponse =
            "Thanks for reaching out to Sphyros Home Services! We've received your request and we'll get back to you soon — usually the same day. — Sphyros Home Services";

          fetch(ENDPOINT, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: JSON.stringify(payload),
          })
            .then(function (res) {
              return res
                .json()
                .catch(function () {
                  return {};
                })
                .then(function (data) {
                  if (res.ok && data && data.success) {
                    form.style.display = "none";
                    thanks.classList.remove("hidden");
                    if (thanks.focus) thanks.focus();
                  } else {
                    throw new Error("Submission failed");
                  }
                });
            })
            .catch(function () {
              if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalLabel;
              }
              errorEl = document.createElement("p");
              errorEl.setAttribute("role", "alert");
              errorEl.className = "mt-3 text-[14px] font-semibold text-amber-dark";
              errorEl.textContent =
                "Something went wrong — please email us directly at info@sphyroshome.com";
              form.appendChild(errorEl);
            });
        });
      }
    })();
  </script>
